# TDNS MP Agent Configuration
# Generated by `tdns-mpcli configure`.

multi-provider:
   role:           agent
   identity:       {{.Agent.Identity}}
   supported_mechanisms: [ dns ]
   long_term_jose_priv_key: {{.Paths.AgentJosePriv}}
   combiner:
      identity:                {{.Combiner.Identity}}
      address:                 {{.CombinerDnsListen}}
      long_term_jose_pub_key:  {{.Paths.CombinerJosePub}}
   signer:
      identity:                {{.Signer.Identity}}
      address:                 {{.SignerDnsListen}}
      long_term_jose_pub_key:  {{.Paths.SignerJosePub}}
   local:
      notify:        []
   remote:
      LocateInterval: 60
   xfr:
      outgoing:
         addresses:  []
         auth:       []
      incoming:
         addresses:  []
         auth:       []
   # api:
   #    addresses:
   #       publish:    [ 127.0.0.1 ]
   #       listen:     [ 127.0.0.1:8999 ]
   #    baseurl:       https://api.{TARGET}:{PORT}/api/v1
   #    port:          8999
   #    certfile:      {{.Paths.AgentCert}}
   #    keyfile:       {{.Paths.AgentKey}}
   dns:
      addresses:
         publish:    [ 127.0.0.1 ]
         listen:     [ 127.0.0.1:8998 ]
      baseurl:       dns://dns.{TARGET}:{PORT}/
      port:          8998
   syncengine:
      intervals:
         beatinterval:       30
         helloretry:         15
         discoveryretry:     15
         hello_fast_attempts: 3
         hello_fast_interval: 2

service:
   name:           TDNS-MPAGENT
   verbose:        true
   debug:          false
   refresh:        true
   maxrefresh:     1800

dnsengine:
   addresses:      [ {{.AgentDnsListen}} ]

apiserver:
   addresses:      [ {{.AgentApiListen}} ]
   apikey:         {{.Agent.ApiKey}}

delegationsync:
   leader-election-ttl: 60m
   child:
      schemes:     [ notify, update ]
      update:
         keygen:
            mode:       internal
            algorithm:  ED25519

keybootstrap:
   consistent-lookup:
      iterations:  3
      interval:    60
      nameservers: all

imrengine:
   active:         true
   root-hints:     /etc/tdns/root.hints
   transports:     [ do53 ]
   require_dnssec_validation: true

dnssecpolicies:
   default:
      algorithm:   ED25519
      ksk:
         lifetime:      forever
         sigvalidity:   168h
      zsk:
         lifetime:      forever
         sigvalidity:   2h

db:
   file:  /var/lib/tdns/tdns-mpagent.db

log:
   file:   /var/log/tdns/tdns-mpagent.log
   level:  info

# templates: and zones: directives may be included from a separate file if wanted
templates:
   - name:           mpzone
     type:           secondary
     store:          map
     options:
        - multi-provider

zones:
   - name:            customer.example.
     template:        mpzone
     primary:         {{.SignerDnsListen}}
