# TDNS MP Agent Configuration
# Generated by `tdns-mpcli configure`.

# Multi-provider config: identity of this agent + its peers
# (combiner and signer), and how each one is reached.
multi-provider:
   role:           agent
   # FQDN identity of this agent; appears in HSYNC3 records and
   # in CHUNK/HELLO/BEAT/PING signatures.
   identity:       {{.Agent.Identity}}
   # Active transport mechanisms ("api", "dns"). Currently only
   # "dns" (NOTIFY+CHUNK over DNS) is fully implemented; the "api"
   # HTTPS transport is partial and not production-ready.
   supported_mechanisms: [ dns ]
   # Path to this agent's long-term JOSE private key (P-256) used
   # to sign outbound CHUNK envelopes and authenticate to peers.
   long_term_jose_priv_key: {{.Paths.AgentJosePriv}}
   # Combiner peer: where this agent sends combiner-bound traffic
   # (UPDATE/SYNC/PING) and whose JOSE public key verifies inbound
   # combiner replies.
   combiner:
      identity:                {{.Combiner.Identity}}
      address:                 {{.CombinerDnsDial}}
      long_term_jose_pub_key:  {{.Paths.CombinerJosePub}}
   # Signer peer: where this agent fetches DNSKEY state (KEYSTATE
   # RFI) and verifies signer-signed responses.
   signer:
      identity:                {{.Signer.Identity}}
      address:                 {{.SignerDnsDial}}
      long_term_jose_pub_key:  {{.Paths.SignerJosePub}}
   # Local zone (auto-created at startup as the agent's identity
   # zone, e.g. agent.example.).
   local:
      # FQDNs published as NS RDATA in the auto-created agent zone.
      nameservers:   [ {{range $i, $ns := .Agent.LocalNameservers}}{{if $i}}, {{end}}{{$ns}}{{end}} ]
      # host:port addresses of downstream secondaries that should
      # receive NOTIFY when the agent zone changes.
      notify:        [ {{range $i, $n := .Agent.LocalNotify}}{{if $i}}, {{end}}{{$n}}{{end}} ]
   remote:
      # Seconds between LocateAgent attempts when a peer is not yet
      # discovered (i.e. before HELLO has succeeded).
      LocateInterval: 60
   # Inter-agent zone-transfer endpoints, advertised on demand via
   # CONFIG upstream/downstream requests from peer agents. Empty
   # lists mean "this agent does not act as XFR source/destination
   # for peer agents" — fine for setups where secondaries pull from
   # the agent's own dnsengine instead.
   xfr:
      outgoing:
         addresses:  []
         auth:       []
      incoming:
         addresses:  []
         auth:       []
   # api:
   #    addresses:
   #       # IP that peers should use to reach this agent's API.
   #       publish:    [ 127.0.0.1 ]
   #       # host:port the API server binds. 0.0.0.0:<port> for any
   #       # interface; specific IP to restrict.
   #       listen:     [ 127.0.0.1:8999 ]
   #    # URL template peers use to construct API calls. {TARGET}
   #    # and {PORT} are substituted at runtime.
   #    baseurl:       https://api.{TARGET}:{PORT}/api/v1
   #    port:          8999
   #    certfile:      {{.Paths.AgentCert}}
   #    keyfile:       {{.Paths.AgentKey}}
   # DNS endpoint (NOTIFY+CHUNK signaling). Distinct from the
   # top-level dnsengine: block; this is the address peers should
   # use to reach this agent for MP traffic.
   dns:
      addresses:
         # Externally-reachable IP advertised to peers.
         publish:    [ {{.Global.PublicIP}} ]
         # host:port the signaling DNS service binds (must match
         # the agent's dnsengine.addresses port).
         listen:     [ {{.AgentDnsListen}} ]
      # URL template published as a DNS URI RR in the agent's
      # auto-created identity zone. Remote agents fetch this URI
      # during their LocateAgent discovery to learn how to reach
      # this agent for MP signaling. {TARGET} and {PORT} are
      # substituted at publication time.
      baseurl:       dns://dns.{TARGET}:{PORT}/
      port:          {{.AgentDnsPort}}
   # Tuning knobs for the gossip + discovery loops. Defaults are
   # sane for production; lower values are useful for testbeds.
   syncengine:
      intervals:
         beatinterval:       30   # seconds between BEATs
         helloretry:         15   # seconds between HELLO retries (steady)
         discoveryretry:     15   # seconds between LocateAgent retries
         hello_fast_attempts: 3   # initial fast HELLO attempts before backoff
         hello_fast_interval: 2   # seconds between the first N HELLO attempts

service:
   name:           TDNS-MPAGENT
   verbose:        true
   debug:          false

# Top-level DNS server (zone serving + AXFR + NOTIFY responder).
# This is the agent's actual DNS service; multi-provider.dns above
# only declares the public-facing endpoint info.
dnsengine:
   # Bind addresses. 0.0.0.0:<port> = any interface.
   addresses:      [ {{.AgentDnsListen}} ]
   # DNS transports enabled. do53 = classic UDP/TCP; also valid:
   # dot, doh, doq (require certfile/keyfile).
   transports:     [ do53 ]

# Management API (used by tdns-mpcli for control/inspection).
apiserver:
   addresses:      [ {{.AgentApiListen}} ]
   # Pre-shared key for X-API-Key auth; matches mpcli's config.
   apikey:         {{.Agent.ApiKey}}
   certfile:       {{.Paths.AgentCert}}
   keyfile:        {{.Paths.AgentKey}}

# Parent-zone delegation sync (for zones the agent is authoritative
# for that have a parent it can send updates to).
delegationsync:
   # How long a leader-elected agent retains the role.
   leader-election-ttl: 60m
   child:
      # Methods the child agent will use to propagate delegation
      # changes to the parent: NOTIFY(CDS/CSYNC) and/or DDNS UPDATE.
      schemes:     [ notify, update ]
      update:
         # Per-zone SIG(0) key material for signing parent UPDATEs.
         keygen:
            mode:       internal
            algorithm:  ED25519

# DNSKEY bootstrap (RFC 8078 trust-anchor publication via parent).
keybootstrap:
   consistent-lookup:
      iterations:  3
      interval:    60   # seconds between iterations
      nameservers: all  # which NS to query for consistency check

# Internal recursive resolver used for IMR-driven lookups
# (e.g. parent DSYNC discovery, agent identity validation).
imrengine:
   active:         true
   root-hints:     /etc/tdns/root.hints
   transports:     [ do53 ]
   # If true, IMR responses must validate DNSSEC; bogus = SERVFAIL.
   require_dnssec_validation: true

# Named DNSSEC policies. Zones reference one via dnssecpolicy:.
dnssecpolicies:
   default:
      algorithm:   ED25519
      # Key Signing Key parameters.
      ksk:
         lifetime:      forever   # "forever" | "none" | Go duration
         sigvalidity:   168h      # RRSIG validity window
      # Zone Signing Key parameters.
      zsk:
         lifetime:      forever
         sigvalidity:   2h
      # Combined Signing Key (single key for everything). lifetime=
      # "none" disables CSK mode in this policy.
      csk:
         lifetime:      none
         sigvalidity:   168h

db:
   file:  /var/lib/tdns/tdns-mpagent.db

log:
   file:   /var/log/tdns/tdns-mpagent.log
   level:  info

# If the templates: and zones: sections grow large, move them to a
# separate YAML file and pull it in via a top-level "include:" entry.
templates:
   - name:           mptest
     type:           secondary
     # Where zone data is held: "map" (in-memory map) is the right
     # choice for MP zones; "slice" and "xfr" exist for other modes.
     store:          map
     primary:        {{.SignerDnsDial}}
     # Zone-level options. "multi-provider" enables the MP pipeline
     # (HSYNC3 evaluation, combiner edits, signer KEYSTATE, etc.).
     options:
        - multi-provider

zones:
   - name:            example.test.
     template:        mptest
