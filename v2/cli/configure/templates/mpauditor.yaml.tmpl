# TDNS MP Auditor Configuration
# Generated by `tdns-mpcli configure`.
#
# The auditor is a read-only multi-provider observer. It joins the
# HSYNC3 protocol (BEAT, HELLO, PING, gossip) and watches signaling
# from other providers, but never contributes zone data. Peers are
# discovered via the same HSYNC3 mechanism as for agents.

# Multi-provider config: auditor's identity and signaling endpoint.
multi-provider:
   role:           auditor
   # FQDN identity of this auditor; appears in HSYNC3 records when
   # the auditor publishes its presence, and in signed signaling
   # envelopes.
   identity:       {{.Auditor.Identity}}
   # Active transport mechanisms. Currently only "dns" (NOTIFY+
   # CHUNK over DNS) is fully implemented; "api" is partial.
   supported_mechanisms: [ dns ]
   # Path to this auditor's long-term JOSE private key (P-256)
   # used to sign outbound CHUNK envelopes and authenticate to
   # peers.
   long_term_jose_priv_key: {{.Paths.AuditorJosePriv}}
   # The auditor has no auto-created identity zone in the usual
   # sense, but the local block is still required by the parser.
   local:
      nameservers:   [ ]
      notify:        [ ]
   remote:
      # Seconds between LocateAgent attempts when a peer is not
      # yet discovered (i.e. before HELLO has succeeded).
      LocateInterval: 60
   # Inter-agent zone-transfer endpoints. The auditor never serves
   # zones to other agents, so these stay empty.
   xfr:
      outgoing:
         addresses:  []
         auth:       []
      incoming:
         addresses:  []
         auth:       []
   # DNS endpoint advertised to peers during discovery.
   dns:
      addresses:
         # Externally-reachable IP advertised to peers.
         publish:    [ {{.Global.PublicIP}} ]
         # host:port the signaling DNS service binds (must match
         # the auditor's dnsengine.addresses port).
         listen:     [ {{.AuditorDnsListen}} ]
      # URL template published as a DNS URI RR for remote agents
      # to learn how to reach this auditor for MP signaling.
      # {TARGET} and {PORT} are substituted at publication time.
      baseurl:       dns://dns.{TARGET}:{PORT}/
      port:          {{.AuditorDnsPort}}
   # Tuning knobs for the gossip + discovery loops. Defaults are
   # sane for production; lower values are useful for testbeds.
   syncengine:
      intervals:
         beatinterval:       30   # seconds between BEATs
         helloretry:         15   # seconds between HELLO retries (steady)
         discoveryretry:     15   # seconds between LocateAgent retries
         hello_fast_attempts: 3   # initial fast HELLO attempts before backoff
         hello_fast_interval: 2   # seconds between the first N HELLO attempts

service:
   name:           TDNS-MPAUDITOR
   verbose:        true
   debug:          false

# Top-level DNS server (signaling endpoint only; no zone serving).
dnsengine:
   # Bind addresses. 0.0.0.0:<port> = any interface.
   addresses:      [ {{.AuditorDnsListen}} ]
   # DNS transports enabled. do53 = classic UDP/TCP.
   transports:     [ do53 ]

# Management API (used by tdns-mpcli for control/inspection).
apiserver:
   addresses:      [ {{.AuditorApiListen}} ]
   # Pre-shared key for X-API-Key auth; matches mpcli's config.
   apikey:         {{.Auditor.ApiKey}}
   certfile:       {{.Paths.AuditorCert}}
   keyfile:        {{.Paths.AuditorKey}}

# Internal recursive resolver used for IMR-driven lookups
# (e.g. agent discovery via HSYNC3 records published in remote
# provider zones).
imrengine:
   active:         true
   root-hints:     /etc/tdns/root.hints
   transports:     [ do53 ]
   # If true, IMR responses must validate DNSSEC; bogus = SERVFAIL.
   require_dnssec_validation: true

db:
   file:  /var/lib/tdns/tdns-mpauditor.db

log:
   file:   /var/log/tdns/tdns-mpauditor.log
   level:  info

# Auditor-specific knobs.
audit:
   event_log:
      # How long observed events are retained.
      retention:        168h
      # How often the event-log pruner runs.
      prune_interval:   1h
   # A provider is flagged as silent if no BEAT arrives within
   # this window.
   silence_threshold:   90s
   # How often the auditor's detectors run (silence, divergence,
   # quorum checks).
   detector_interval:   30s
   # Optional web dashboard. Disabled by default; enable by
   # setting `enabled: true` and supplying cert/key files for
   # HTTPS (or set both empty for a loopback-only HTTP fallback).
   web:
      enabled:          false
      addresses:        [ 127.0.0.1:8099 ]
      cert_file:        ""
      key_file:         ""
      auth:
         mode:          basic
         idle_timeout:  30m
         users_file:    /etc/tdns/tdns-auditor-users.yaml
