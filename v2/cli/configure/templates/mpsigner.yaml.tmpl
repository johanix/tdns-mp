# TDNS MP Signer Configuration
# Generated by `tdns-mpcli configure`.

# Multi-provider config: signer's identity, peers (agents), and
# whether this signer is currently active in the MP pipeline.
multi-provider:
   role:      signer
   # When false, the signer accepts traffic but does not sign zones.
   # Used to retire a signer from a multi-signer setup gracefully.
   active:    true
   # FQDN identity of this signer; appears in HSYNCPARAM.signers
   # to declare it as a signing provider for a zone.
   identity:  {{.Signer.Identity}}
   long_term_jose_priv_key:  {{.Paths.SignerJosePriv}}

   # Agent peers this signer expects to talk to. Each entry must
   # match an agent's identity FQDN; address is where to dial it.
   agents:
      - identity:               {{.Agent.Identity}}
        address:                {{.AgentDnsDial}}
        long_term_jose_pub_key: {{.Paths.AgentJosePub}}

   # Optional HTTPS sync API (alternative to NOTIFY+CHUNK for
   # HELLO/BEAT/PING). Disabled by default — DNS transport is the
   # primary mechanism.
   # sync_api:
   #    addresses:
   #       listen:     [ 127.0.0.1:8991 ]
   #    cert_file:     {{.Paths.SignerCert}}
   #    key_file:      {{.Paths.SignerKey}}

service:
   name:           TDNS-MPSIGNER
   verbose:        true
   debug:          false
   # When true the ResignerEngine periodically re-signs zones to
   # refresh RRSIG validity. False means re-sign only on explicit
   # triggers (key state changes, ZONEMD updates, etc.).
   resign:         true

# Top-level DNS server (zone serving + AXFR + NOTIFY responder).
dnsengine:
   # Bind addresses. The signer typically binds both its high port
   # (for MP signaling) and 53 (for client queries).
   addresses:      [ {{.SignerDnsListen}}, {{.SignerDnsListen53}} ]
   transports:     [ do53 ]

apiserver:
   addresses:      [ {{.SignerApiListen}} ]
   apikey:         {{.Signer.ApiKey}}
   certfile:       {{.Paths.SignerCert}}
   keyfile:        {{.Paths.SignerKey}}

# Periodic re-signing schedule for the signer.
resignerengine:
   # Seconds between re-sign passes. Each pass checks every signed
   # zone for RRSIG headroom against KASP.propagation_delay.
   interval:       300
   # How key material for newly-introduced zones is provisioned.
   keygen:
      mode:        internal   # internal | external (HSM, etc.)
      algorithm:   ED25519

# Key and Signing Policy: knobs that drive the KeyStateWorker's
# automatic state transitions and standby-key maintenance.
kasp:
   # How long to wait for DNSKEY changes to propagate before
   # advancing key state (published -> standby, retired -> removed).
   propagation_delay:  1h
   # How often the KeyStateWorker runs its checks.
   check_interval:     1m
   # Number of standby ZSKs to keep ready per zone. KeyStateWorker
   # generates new ones when the count drops below this.
   standby_zsk_count:  1
   # Same for KSKs. 0 = no standby KSKs (manual rollover only).
   standby_ksk_count:  0

# Named DNSSEC policies. Zones reference one via dnssecpolicy:.
dnssecpolicies:
   default:
      algorithm:  ED25519
      # Key Signing Key parameters.
      ksk:
         lifetime:      forever   # "forever" | "none" | Go duration
         sigvalidity:   168h      # RRSIG validity window
      # Zone Signing Key parameters.
      zsk:
         lifetime:      forever
         sigvalidity:   2h
      # Combined Signing Key (single key for everything). lifetime=
      # "none" disables CSK mode in this policy.
      csk:
         lifetime:      none
         sigvalidity:   168h

db:
   file:  /var/lib/tdns/tdns-mpsigner.db

log:
   file:   /var/log/tdns/tdns-mpsigner.log
   level:  info

# If the templates: and zones: sections grow large, move them to a
# separate YAML file and pull it in via a top-level "include:" entry.
templates:
   - name:           mptest
     type:           secondary
     store:          map
     # Signer pulls zone data from the combiner (which itself pulls
     # from the customer's authoritative primary or accepts UPDATEs).
     primary:        {{.CombinerDnsDial}}
     options:
        - multi-provider
     # Policy applied if HSYNCPARAM puts this signer in the active
     # signers set; otherwise this signer just relays unsigned data.
     dnssecpolicy:   default
     # After re-signing, NOTIFY the agent so it pulls the new
     # serial and serves the freshly-signed zone.
     notify:         [ {{.AgentDnsDial}} ]

zones:
   - name:            example.test.
     template:        mptest
