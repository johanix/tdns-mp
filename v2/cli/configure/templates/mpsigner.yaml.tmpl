# TDNS MP Signer Configuration
# Generated by `tdns-mpcli configure`.

multi-provider:
   role:      signer
   active:    true
   identity:  {{.Signer.Identity}}
   long_term_jose_priv_key:  {{.Paths.SignerJosePriv}}

   agents:
      - identity:               {{.Agent.Identity}}
        address:                {{.AgentDnsListen}}
        long_term_jose_pub_key: {{.Paths.AgentJosePub}}

   # sync_api:
   #    addresses:
   #       listen:     [ 127.0.0.1:8991 ]
   #    cert_file:     {{.Paths.SignerCert}}
   #    key_file:      {{.Paths.SignerKey}}

service:
   name:           TDNS-MPSIGNER
   verbose:        true
   debug:          false
   refresh:        true
   maxrefresh:     1800

dnsengine:
   addresses:      [ {{.SignerDnsListen}}, {{.SignerDnsListen53}} ]

apiserver:
   addresses:      [ {{.SignerApiListen}} ]
   apikey:         {{.Signer.ApiKey}}

resignerengine:
   interval:       300
   keygen:
      mode:        internal
      algorithm:   ED25519

kasp:
   propagation_delay:  1h
   check_interval:     1m
   standby_zsk_count:  1
   standby_ksk_count:  0

dnssecpolicies:
   default:
      algorithm:  ED25519
      ksk:
         lifetime:      forever
         sigvalidity:   168h
      zsk:
         lifetime:      forever
         sigvalidity:   2h

db:
   file:  /var/lib/tdns/tdns-mpsigner.db

log:
   file:   /var/log/tdns/tdns-mpsigner.log
   level:  info

# templates: and zones: directives may be included from a separate file if wanted
templates:
   - name:           mpzone
     type:           secondary
     store:          map
     options:
        - multi-provider
     notify:         [ {{.AgentDnsListen}} ]

zones:
   - name:            customer.example.
     template:        mpzone
     primary:         {{.CombinerDnsListen}}
