# TDNS MP Combiner Configuration
# Generated by `tdns-mpcli configure`.

# Multi-provider config: combiner's identity and which agents it
# accepts edits/SYNCs from.
multi-provider:
   role:      combiner
   # FQDN identity of this combiner; verified by peers against the
   # JOSE public key they have for it.
   identity:  {{.Combiner.Identity}}
   long_term_jose_priv_key:  {{.Paths.CombinerJosePriv}}

   # Agent peers this combiner accepts edits from. Each entry must
   # match an agent's identity FQDN; address is where the combiner
   # dials the agent (e.g. to deliver CHUNK responses).
   agents:
      - identity:               {{.Agent.Identity}}
        address:                {{.AgentDnsDial}}
        long_term_jose_pub_key: {{.Paths.AgentJosePub}}

   # Optional HTTPS sync API (alternative to NOTIFY+CHUNK).
   # Disabled by default — DNS transport is the primary mechanism.
   # sync_api:
   #    addresses:
   #       listen:     [ 127.0.0.1:8992 ]
   #    cert_file:     {{.Paths.CombinerCert}}
   #    key_file:      {{.Paths.CombinerKey}}

service:
   name:           TDNS-MPCOMBINER
   verbose:        true
   debug:          false

# Top-level DNS server. The combiner answers AXFR requests from
# its signer (which is configured as its downstream secondary).
dnsengine:
   addresses:      [ {{.CombinerDnsListen}} ]
   transports:     [ do53 ]

apiserver:
   addresses:      [ {{.CombinerApiListen}} ]
   apikey:         {{.Combiner.ApiKey}}
   certfile:       {{.Paths.CombinerCert}}
   keyfile:        {{.Paths.CombinerKey}}

db:
   file:  /var/lib/tdns/tdns-mpcombiner.db

log:
   file:   /var/log/tdns/tdns-mpcombiner.log
   level:  info

# If the templates: and zones: sections grow large, move them to a
# separate YAML file and pull it in via a top-level "include:" entry.
templates:
   - name:           mptest
     # Combiner is primary for the combined zone — it receives
     # edits from agents and (optionally) merges them with data
     # from the customer's authoritative primary.
     type:           primary
     store:          map
     options:
        - multi-provider
     # After combining, NOTIFY the signer so it pulls the new
     # serial and signs it.
     notify:         [ {{.SignerDnsDial}} ]

zones:
   - name:            example.test.
     template:        mptest
     # Set `primary:` to the customer's authoritative primary
     # when this combiner pulls a real zone, e.g.:
     # primary:         203.0.113.53:53
