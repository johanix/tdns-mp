# TDNS MP CLI Configuration
# Generated by `tdns-mpcli configure`.

# API servers this CLI can talk to. `name:` is what the operator
# selects on the command line (e.g. `tdns-mpcli signer ...`).
# baseurl: uses the public IP so the CLI works from the operator's
# workstation; the apikey must match each daemon's apiserver.apikey.
# command: path to the daemon binary, used by `tdns-mpcli ... start`
# and similar lifecycle commands.
apiservers:
   - name:         tdns-mpsigner
     baseurl:      https://{{.SignerApiPublic}}/api/v1
     apikey:       {{.Signer.ApiKey}}
     authmethod:   X-API-Key
     command:      /usr/local/libexec/tdns-mpsigner

   - name:         tdns-mpcombiner
     baseurl:      https://{{.CombinerApiPublic}}/api/v1
     apikey:       {{.Combiner.ApiKey}}
     authmethod:   X-API-Key
     command:      /usr/local/libexec/tdns-mpcombiner

   - name:         tdns-mpagent
     baseurl:      https://{{.AgentApiPublic}}/api/v1
     apikey:       {{.Agent.ApiKey}}
     authmethod:   X-API-Key
     command:      /usr/local/libexec/tdns-mpagent
{{if .Auditor.Identity}}
   - name:         tdns-mpauditor
     baseurl:      https://{{.AuditorApiPublic}}/api/v1
     apikey:       {{.Auditor.ApiKey}}
     authmethod:   X-API-Key
     command:      /usr/local/libexec/tdns-mpauditor
{{end}}
log:
   file:   /var/log/tdns/tdns-mpcli.log
   level:  info
