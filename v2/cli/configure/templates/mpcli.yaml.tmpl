# TDNS MP CLI Configuration
# Generated by `tdns-mpcli configure`.

# API servers this CLI can talk to. `name:` is what the operator
# selects on the command line (e.g. `tdns-mpcli signer ...`).
# baseurl: uses the internal IP (same as the daemons' apiserver
# bind), which is the only address reachable from the same host in
# NAT'd setups like AWS EC2 where the public IP isn't on any local
# interface. For remote mpcli use (operator's workstation), edit
# this to the externally-reachable host:port and arrange SSH tunnel
# or firewall access as appropriate.
# command: path to the daemon binary, used by `tdns-mpcli ... start`
# and similar lifecycle commands.
apiservers:
   - name:         tdns-mpsigner
     baseurl:      https://{{.SignerApiListen}}/api/v1
     apikey:       {{.Signer.ApiKey}}
     authmethod:   X-API-Key
     command:      /usr/local/libexec/tdns-mpsigner

   - name:         tdns-mpcombiner
     baseurl:      https://{{.CombinerApiListen}}/api/v1
     apikey:       {{.Combiner.ApiKey}}
     authmethod:   X-API-Key
     command:      /usr/local/libexec/tdns-mpcombiner

   - name:         tdns-mpagent
     baseurl:      https://{{.AgentApiListen}}/api/v1
     apikey:       {{.Agent.ApiKey}}
     authmethod:   X-API-Key
     command:      /usr/local/libexec/tdns-mpagent
{{if .Auditor.Identity}}
   - name:         tdns-mpauditor
     baseurl:      https://{{.AuditorApiListen}}/api/v1
     apikey:       {{.Auditor.ApiKey}}
     authmethod:   X-API-Key
     command:      /usr/local/libexec/tdns-mpauditor
{{end}}
log:
   file:   /var/log/tdns/tdns-mpcli.log
   level:  info
